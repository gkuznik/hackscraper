<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Find your next Hackathon" suffix=" · HackScraper">
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" type="image/x-icon" href="/images/logo.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <link rel="manifest" href="/favicon/site.webmanifest">
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="bg-white antialiased flex flex-col min-h-screen">
    <ul class="relative z-10 flex items-center gap-4 py-4 px-4 sm:px-6 lg:px-8 justify-between">
      <li class="flex items-center gap-4">
        <a href="/">
          <img src={~p"/images/logo.png"} width="36" />
        </a>
        <p class="bg-brand/5 text-brand rounded-full px-2 font-medium leading-6">
          v{Application.spec(:phoenix, :vsn)}
        </p>
      </li>
      <div class="flex items-center gap-4">
        <%= if @current_user do %>
          <li class="text-[0.8125rem] leading-6 text-zinc-900">
            {@current_user.name}
          </li>
          <li>
            <.link
              href={~p"/users/settings"}
              class="text-[0.8125rem] leading-6 text-zinc-900 font-semibold hover:text-zinc-700"
            >
              Settings
            </.link>
          </li>
          <li>
            <.link
              href={~p"/users/log_out"}
              method="delete"
              class="text-[0.8125rem] leading-6 text-zinc-900 font-semibold hover:text-zinc-700"
            >
              Log out
            </.link>
          </li>
        <% else %>
          <li>
            <.link
              href={~p"/users/register"}
              class="text-[0.8125rem] leading-6 text-zinc-900 font-semibold hover:text-zinc-700"
            >
              Register
            </.link>
          </li>
          <li>
            <.link
              href={~p"/users/log_in"}
              class="text-[0.8125rem] leading-6 text-zinc-900 font-semibold hover:text-zinc-700"
            >
              Log in
            </.link>
          </li>
        <% end %>
      </div>
    </ul>
    {@inner_content}

    <div class="grow"></div>
    <footer class="bg-gray-900 py-12 w-full">
      <div class="text-center mx-auto px-4 sm:px-6 lg:px-8">
        <h3 class="text-2xl text-white font-bold mb-4">HackScraper</h3>
        <p class="text-gray-400 mb-6">
          Your ultimate destination for discovering hackathons worldwide
        </p>
        <div class="flex justify-center space-x-6">
          <.link
            navigate={~p"/hackathons"}
            class="text-gray-400 hover:text-white transition-colors"
          >
            Hackathons
          </.link>
          <.link navigate={~p"/series"} class="text-gray-400 hover:text-white transition-colors">
            Series
          </.link>
        </div>
      </div>
    </footer>
  </body>
</html>
